{
  "name": "@open-enterprise/server",
  "version": "1.2.9",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed-masters": "node scripts/seed-connection-masters.js",
    "build:bundle": "ncc build cli/index.js --out cli/bundle --external oracledb --external better-sqlite3 --external snowflake-sdk --external mssql",
    "build:win": "npm run build:bundle && node --experimental-sea-config sea-config.json && node scripts/inject-sea.js",
    "build:all": "npm run build:win"
  },
  "pkg": {
    "scripts": [
      "src/engine/**/*.js",
      "src/utils/tools/**/*.js",
      "src/providers/**/*.js"
    ],
    "assets": [
      "cli/oe-config.example.json"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-arm64"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@elastic/elasticsearch": "^9.4.2",
    "@google-cloud/bigquery": "^8.3.1",
    "@lancedb/lancedb": "0.14.0",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@modelcontextprotocol/server-postgres": "^0.6.2",
    "@pinecone-database/pinecone": "^3.0.0",
    "@prisma/client": "^5.22.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "@zilliz/milvus2-sdk-node": "^2.4.6",
    "apache-arrow": "^17.0.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "chromadb": "^1.9.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "form-data": "^4.0.1",
    "googleapis": "^173.0.0",
    "imapflow": "^1.4.3",
    "ioredis": "^5.11.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "ldapts": "^9.0.0",
    "mongodb": "^7.3.0",
    "mqtt": "^5.15.2",
    "mssql": "^12.5.5",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.5",
    "node-cron": "^4.4.1",
    "nodemailer": "^9.0.1",
    "openai": "^4.67.3",
    "oracledb": "^7.0.0",
    "pg": "^8.12.0",
    "pgvector": "^0.2.0",
    "snowflake-sdk": "^3.0.0",
    "ssh2": "^1.17.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.44.1",
    "@yao-pkg/pkg": "^6.21.0",
    "nodemon": "^3.1.7",
    "pkg": "^5.8.1",
    "prisma": "^5.22.0"
  }
}
