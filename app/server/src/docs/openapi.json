{
  "openapi": "3.0.3",
  "info": {
    "title": "Open Enterprise REST API",
    "version": "1.3.1",
    "description": "Developer API for integrating documents and agents with Open Enterprise.\n\n## Authentication\nAll endpoints require an API key. Generate one in **Admin Panel → API Keys**.\n\nInclude it in every request as a Bearer token:\n```\nAuthorization: Bearer emb_your_api_key_here\n```\n\n## Base URL\nAll endpoints are relative to your Open Enterprise instance URL, e.g. `https://your-domain.com/api/v1`"
  },
  "servers": [
    { "url": "/api/v1", "description": "This Open Enterprise instance" }
  ],
  "security": [
    { "ApiKeyAuth": [] }
  ],
  "tags": [
    { "name": "Agents",    "description": "List and run AI agents" },
    { "name": "Documents", "description": "Upload, ingest, and manage documents" }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Open Enterprise API Key",
        "description": "Create an API key in Admin Panel → API Keys. Keys start with `emb_`."
      }
    },
    "schemas": {
      "Document": {
        "type": "object",
        "properties": {
          "uid":             { "type": "string",  "example": "abc123-def456" },
          "name":            { "type": "string",  "example": "Employee Handbook 2024.pdf" },
          "type":            { "type": "string",  "example": "application/pdf" },
          "size":            { "type": "integer", "example": 204800, "description": "File size in bytes" },
          "status":          { "type": "string",  "enum": ["queued","ingesting","ready","partial","failed"], "example": "ready" },
          "chunkCount":      { "type": "integer", "example": 48 },
          "chunksProcessed": { "type": "integer", "example": 48 },
          "totalChunks":     { "type": "integer", "example": 48 },
          "errorMessage":    { "type": "string",  "nullable": true },
          "createdAt":       { "type": "string",  "format": "date-time" }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "id":             { "type": "integer", "example": 1 },
          "name":           { "type": "string",  "example": "Daily Report Agent" },
          "slug":           { "type": "string",  "example": "daily-report-agent" },
          "triggerType":    { "type": "string",  "enum": ["manual","scheduled"], "example": "scheduled" },
          "cronExpression": { "type": "string",  "example": "0 9 * * *", "nullable": true },
          "enabled":        { "type": "boolean", "example": true },
          "createdAt":      { "type": "string",  "format": "date-time" }
        }
      },
      "AgentRun": {
        "type": "object",
        "properties": {
          "id":          { "type": "integer", "example": 42 },
          "status":      { "type": "string",  "enum": ["running","success","error"], "example": "success" },
          "triggerType": { "type": "string",  "enum": ["manual","scheduled"], "example": "manual" },
          "input":       { "type": "string",  "nullable": true },
          "output":      { "type": "string",  "nullable": true },
          "error":       { "type": "string",  "nullable": true },
          "startedAt":   { "type": "string",  "format": "date-time" },
          "completedAt": { "type": "string",  "format": "date-time", "nullable": true }
        }
      },
      "DocumentQueued": {
        "type": "object",
        "properties": {
          "uid":    { "type": "string",  "example": "abc123-def456" },
          "name":   { "type": "string",  "example": "report.pdf" },
          "status": { "type": "string",  "example": "queued" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "Workspace not found" }
        }
      }
    }
  },
  "paths": {

    "/workspaces/{workspaceSlug}/documents": {
      "get": {
        "summary": "List documents",
        "operationId": "listDocuments",
        "tags": ["Documents"],
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Workspace slug", "example": "hr-policy-documents" }
        ],
        "responses": {
          "200": {
            "description": "List of documents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "documents": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } } }
                }
              }
            }
          },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/documents/{uid}": {
      "get": {
        "summary": "Get document status",
        "operationId": "getDocument",
        "tags": ["Documents"],
        "description": "Poll ingestion status after uploading. `status` progresses: `queued` → `ingesting` → `ready` (or `failed`).",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" },
          { "name": "uid", "in": "path", "required": true, "schema": { "type": "string" }, "example": "abc123-def456" }
        ],
        "responses": {
          "200": {
            "description": "Document details",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "document": { "$ref": "#/components/schemas/Document" } } }
              }
            }
          },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Document not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "summary": "Delete document",
        "operationId": "deleteDocument",
        "tags": ["Documents"],
        "description": "Deletes the document record and removes its vectors from the index.",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" },
          { "name": "uid", "in": "path", "required": true, "schema": { "type": "string" }, "example": "abc123-def456" }
        ],
        "responses": {
          "200": { "description": "Document deleted", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" } } } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Document not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/documents/upload": {
      "post": {
        "summary": "File upload",
        "operationId": "uploadFile",
        "tags": ["Documents"],
        "description": "Upload a single document file (PDF, DOCX, DOC, TXT, MD, CSV, XLSX, XLS, JSON). Ingestion is async — poll `GET /documents/{uid}` until `status` is `ready`.",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string", "format": "binary", "description": "The document file to upload" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "File queued for ingestion", "content": { "application/json": { "schema": { "type": "object", "properties": { "documents": { "type": "array", "items": { "$ref": "#/components/schemas/DocumentQueued" } } } } } } },
          "400": { "description": "No file provided or storage limit exceeded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/documents/folder": {
      "post": {
        "summary": "Folder upload",
        "operationId": "uploadFolder",
        "tags": ["Documents"],
        "description": "Upload multiple files from a folder in a single request. Send each file as a separate `file` field. All files are queued for ingestion in parallel.",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "array", "items": { "type": "string", "format": "binary" }, "description": "One or more files. Repeat the `file` field for each file in the folder." }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Files queued for ingestion", "content": { "application/json": { "schema": { "type": "object", "properties": { "documents": { "type": "array", "items": { "$ref": "#/components/schemas/DocumentQueued" } } } } } } },
          "400": { "description": "No files provided or storage limit exceeded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/documents/ocr": {
      "post": {
        "summary": "OCR (image files)",
        "operationId": "uploadOcr",
        "tags": ["Documents"],
        "description": "Upload image file(s) for OCR ingestion. Uses LLM vision to extract text from the image. Supported: JPG, JPEG, PNG, GIF, WEBP, TIFF, BMP.",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "array", "items": { "type": "string", "format": "binary" }, "description": "One or more image files to process via OCR" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Images queued for OCR ingestion", "content": { "application/json": { "schema": { "type": "object", "properties": { "documents": { "type": "array", "items": { "$ref": "#/components/schemas/DocumentQueued" } } } } } } },
          "400": { "description": "No files provided", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/documents/website": {
      "post": {
        "summary": "Website ingestion",
        "operationId": "ingestWebsite",
        "tags": ["Documents"],
        "description": "Ingest a web page or crawl an entire website. Set `crawl: true` to BFS-crawl all pages on the same domain.",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url":      { "type": "string",  "example": "https://docs.example.com" },
                  "crawl":    { "type": "boolean", "default": false, "example": true, "description": "Set true to crawl all pages on the same domain (BFS)" },
                  "maxPages": { "type": "integer", "default": 50,    "example": 50,   "description": "Max pages to crawl (crawl mode only)" },
                  "maxDepth": { "type": "integer", "default": 2,     "example": 2,    "description": "Max link depth from start URL (crawl mode only)" }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Website queued for ingestion",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "document": { "$ref": "#/components/schemas/DocumentQueued" },
                    "crawl":    { "type": "object", "description": "Present only when crawl: true", "properties": { "maxPages": { "type": "integer" }, "maxDepth": { "type": "integer" } } }
                  }
                }
              }
            }
          },
          "400": { "description": "url is required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/documents/cloud": {
      "post": {
        "summary": "Cloud storage",
        "operationId": "ingestCloud",
        "tags": ["Documents"],
        "description": "Download and ingest a file from cloud storage via a direct URL. Works with:\n- **AWS S3** pre-signed URLs\n- **Google Drive** direct download links (`/uc?export=download&id=...`)\n- **Dropbox** direct links (add `?dl=1` to sharing URL)\n- Any publicly accessible file URL",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url": { "type": "string", "example": "https://my-bucket.s3.amazonaws.com/report.pdf?X-Amz-Signature=...", "description": "Direct download URL to the file in cloud storage" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "File queued for ingestion", "content": { "application/json": { "schema": { "type": "object", "properties": { "document": { "$ref": "#/components/schemas/DocumentQueued" } } } } } },
          "400": { "description": "url is required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/agents": {
      "get": {
        "summary": "List agents",
        "operationId": "listAgents",
        "tags": ["Agents"],
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" }
        ],
        "responses": {
          "200": {
            "description": "List of agents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "agents": { "type": "array", "items": { "$ref": "#/components/schemas/Agent" } } }
                }
              }
            }
          },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Workspace not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/agents/{agentSlug}/runs": {
      "get": {
        "summary": "Get agent run history",
        "operationId": "getAgentRuns",
        "tags": ["Agents"],
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" },
          { "name": "agentSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "daily-report-agent" }
        ],
        "responses": {
          "200": {
            "description": "Last 20 runs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "runs": { "type": "array", "items": { "$ref": "#/components/schemas/AgentRun" } } }
                }
              }
            }
          },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Agent not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/workspaces/{workspaceSlug}/agents/{agentSlug}/run": {
      "post": {
        "summary": "Run agent",
        "operationId": "runAgent",
        "tags": ["Agents"],
        "description": "Triggers an agent run and streams output as **Server-Sent Events**.\n\n**Event types:**\n- `{ \"tool_calls\": [\"conn_1_search_issues\"] }` — agent is calling a tool\n- `{ \"done\": true, \"output\": \"...\", \"runId\": 42, \"pendingApprovals\": 0 }` — run completed (pendingApprovals > 0 means a chain is waiting for human approval in the UI)\n- `{ \"error\": \"...\" }` — run failed",
        "parameters": [
          { "name": "workspaceSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "hr-policy-documents" },
          { "name": "agentSlug", "in": "path", "required": true, "schema": { "type": "string" }, "example": "daily-report-agent" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "input": { "type": "string", "description": "Optional instruction or task for the agent" },
                  "params": { "type": "object", "description": "Parameter values to inject into {{placeholder}} fields in the agent's system prompt", "additionalProperties": { "type": "string" } }
                },
                "example": {
                  "input": "Run",
                  "params": {
                    "customer": "Demo Corp",
                    "date": "2026-07-21"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream of agent output",
            "content": {
              "text/event-stream": {
                "schema": { "type": "string" },
                "example": "data: {\"tool_calls\":[\"conn_1_search_issues\"]}\n\ndata: {\"done\":true,\"output\":\"Found 3 open tickets...\",\"runId\":42}\n\n"
              }
            }
          },
          "401": { "description": "Invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Agent not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "429": { "description": "Monthly agent run limit reached", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }

  }
}
