generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../storage/openenterprise.db"
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String?
  role          String    @default("user")
  suspended     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspaceUsers    WorkspaceUser[]
  chats             Chat[]
  activityLogs      ActivityLog[]
  createdWorkspaces Workspace[] @relation("WorkspaceCreator")
  apiKeys           ApiKey[]    @relation("ApiKeyCreator")
  createdAgents        Agent[]     @relation("AgentCreator")
  triggeredAgentRuns   AgentRun[]  @relation("AgentRunTrigger")
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  createdById Int?
  lastUsedAt  DateTime?
  revoked     Boolean   @default(false)
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())

  createdBy User? @relation("ApiKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  name         String
  systemPrompt          String?
  temperature           Float    @default(0.7)
  chatHistory           Int      @default(20)
  queryRefusalResponse  String?
  starterPrompts        String?
  vectorDbProvider      String?
  vectorDbConfig        String?
  embedEnabled          Boolean  @default(false)
  dlpEnabled            Boolean  @default(false)
  defaultAgentMaxRounds Int      @default(25)
  maxChainDepth         Int      @default(5)
  agentMemoryEnabled    Boolean  @default(false)
  agentMemoryRuns       Int      @default(5)
  createdByUserId       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy  User?          @relation("WorkspaceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  users      WorkspaceUser[]
  documents  Document[]
  chats      Chat[]
  threads    Thread[]
  connectors    Connector[]
  agents        Agent[]
  agentShares      AgentShare[]
  connectorShares  ConnectorShare[]
  chainApprovals ChainApproval[]
  kbSharesAsSource WorkspaceKBShare[] @relation("KBShareSource")
  kbSharesAsTarget WorkspaceKBShare[] @relation("KBShareTarget")
  dlpPolicies      WorkspaceDlpPolicy[]
}

model Connector {
  id           Int       @id @default(autoincrement())
  workspaceId  Int
  name         String    @unique
  slug         String?   @unique
  type         String
  config       String?
  authConfig   String?
  status       String    @default("active")
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  syncs     ConnectorSync[]
  shares    ConnectorShare[]
}

model ConnectorSync {
  id          Int       @id @default(autoincrement())
  connectorId Int
  status      String
  message     String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  connector Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
}

model Thread {
  id          Int      @id @default(autoincrement())
  uid         String   @unique
  workspaceId Int
  name        String   @default("New Thread")
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chats     Chat[]
}

model WorkspaceUser {
  id          Int       @id @default(autoincrement())
  userId      Int
  workspaceId Int
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Document {
  id                Int      @id @default(autoincrement())
  uid               String   @unique
  name              String
  type              String
  size              Int?
  workspaceId       Int
  chunkCount        Int      @default(0)
  status            String   @default("queued")
  cancelRequested   Boolean  @default(false)
  chunksProcessed   Int      @default(0)
  totalChunks       Int      @default(0)
  errorMessage      String?
  sourcePath        String?
  batchId           String?
  connectorId       Int?
  uploadedByUserId  Int?
  embeddingTokens   Int      @default(0)
  embeddingModel    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Chat {
  id           Int      @id @default(autoincrement())
  workspaceId  Int
  threadId     Int?
  userId       Int?
  role         String
  content      String
  sources      String?
  toolCalls     String?
  visualization String?
  inputTokens   Int      @default(0)
  outputTokens Int      @default(0)
  model        String?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  thread    Thread?   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  userEmail String?
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Agent {
  id              Int        @id @default(autoincrement())
  workspaceId     Int
  name            String
  slug            String?   @unique
  description     String?
  systemPrompt    String?
  workflow           String?
  group              String?
  nextAgent          String?
  nextAgentCondition String?
  chains             String?
  connectorIds    String     @default("[]")
  params          String     @default("[]")
  triggerType     String     @default("manual")
  cronExpression  String?
  enabled         Boolean    @default(true)
  visualize       Boolean    @default(false)
  maxRounds       Int?
  createdByUserId Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User?        @relation("AgentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  runs           AgentRun[]
  shares         AgentShare[]
  chainApprovals ChainApproval[]
}

model AgentShare {
  id                 Int       @id @default(autoincrement())
  agentId            Int
  grantedWorkspaceId Int
  createdAt          DateTime  @default(now())

  agent            Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  grantedWorkspace Workspace @relation(fields: [grantedWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([agentId, grantedWorkspaceId])
}

model ConnectorShare {
  id                 Int       @id @default(autoincrement())
  connectorId        Int
  grantedWorkspaceId Int
  createdAt          DateTime  @default(now())

  connector        Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  grantedWorkspace Workspace @relation(fields: [grantedWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([connectorId, grantedWorkspaceId])
}

model AgentRun {
  id                        Int       @id @default(autoincrement())
  agentId                   Int
  triggeredByUserId         Int?
  triggeredFromWorkspaceId  Int?
  status                    String    @default("pending")
  triggerType               String    @default("manual")
  input                     String?
  output                    String?
  error                     String?
  cancelRequested           Boolean   @default(false)
  startedAt                 DateTime  @default(now())
  completedAt               DateTime?

  agent       Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  triggeredBy User? @relation("AgentRunTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
}

model WorkspaceKBShare {
  id                 Int      @id @default(autoincrement())
  sourceWorkspaceId  Int
  targetWorkspaceId  Int
  createdAt          DateTime @default(now())

  sourceWorkspace Workspace @relation("KBShareSource", fields: [sourceWorkspaceId], references: [id], onDelete: Cascade)
  targetWorkspace Workspace @relation("KBShareTarget", fields: [targetWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([sourceWorkspaceId, targetWorkspaceId])
}

model ChainApproval {
  id              Int       @id @default(autoincrement())
  workspaceId     Int
  sourceAgentId   Int
  sourceRunId     Int
  threadId        Int?
  nextAgentSlug   String
  condition       String
  runOutput       String?
  status          String    @default("pending")
  decidedAt       DateTime?
  decidedByUserId Int?
  createdAt       DateTime  @default(now())
  timeoutAt       DateTime

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceAgent Agent     @relation(fields: [sourceAgentId], references: [id], onDelete: Cascade)
}

model DlpPolicy {
  id        Int      @id @default(autoincrement())
  name      String
  category  String   // "passwords" | "ip_addresses" | "api_keys" | "credit_cards" | "custom"
  pattern   String   // regex string
  action    String   @default("block")  // "block" | "warn" | "redact" | "audit"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  workspaces WorkspaceDlpPolicy[]
}

model WorkspaceDlpPolicy {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  policyId    Int
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  policy    DlpPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, policyId])
}

model ConnectionMaster {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  label       String
  category    String
  color       String
  initial     String
  adapterType String?
  fields      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DlpViolation {
  id            Int      @id @default(autoincrement())
  policyId      Int
  policyName    String
  action        String
  userId        Int?
  userEmail     String?
  workspaceId   Int?
  workspaceName String?
  snippet       String
  createdAt     DateTime @default(now())
}
