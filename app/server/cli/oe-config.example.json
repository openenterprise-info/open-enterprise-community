{
  "llm": {
    "provider": "openai",
    "apiKey": "sk-YOUR_OPENAI_KEY",
    "model": "gpt-4o"
  },
  "connectors": [

    // ── IMPORTANT ────────────────────────────────────────────────────────────
    // connection_name and connection_type must exactly match what is defined
    // in your agent YAML file under the connectors section.
    // The runtime uses these to link credentials here to connectors in the YAML.
    // ─────────────────────────────────────────────────────────────────────────

    // ── Native adapters (non-HTTP protocols) ─────────────────────────────────

    {
      "connection_name": "My Server",
      "connection_type": "ssh",
      "host": "YOUR_SERVER_IP",
      "port": 22,
      "username": "ubuntu",
      "privateKeyPath": "~/.ssh/id_rsa"
    },
    {
      "connection_name": "MySQL DB",
      "connection_type": "mysql",
      "host": "localhost",
      "port": 3306,
      "user": "root",
      "password": "YOUR_PASSWORD",
      "database": "your_db"
    },
    {
      "connection_name": "Postgres DB",
      "connection_type": "postgres",
      "host": "localhost",
      "port": 5432,
      "user": "postgres",
      "password": "YOUR_PASSWORD",
      "database": "your_db"
    },
    {
      "connection_name": "MongoDB",
      "connection_type": "mongodb",
      "connectionString": "mongodb://localhost:27017/your_db"
    },
    {
      "connection_name": "Redis",
      "connection_type": "redis",
      "host": "localhost",
      "port": 6379,
      "password": "YOUR_PASSWORD"
    },
    {
      "connection_name": "Zoho Mail",
      "connection_type": "smtp",
      "host": "smtp.zoho.com",
      "port": 465,
      "secure": true,
      "user": "you@yourdomain.com",
      "pass": "YOUR_APP_PASSWORD"
    },
    {
      "connection_name": "Zoho Inbox",
      "connection_type": "imap",
      "host": "imap.zoho.com",
      "port": 993,
      "secure": true,
      "user": "you@yourdomain.com",
      "pass": "YOUR_APP_PASSWORD"
    },
    {
      "connection_name": "Google Drive",
      "connection_type": "gdrive",
      "clientId": "YOUR_GOOGLE_CLIENT_ID",
      "clientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
      "accessToken": "YOUR_GOOGLE_ACCESS_TOKEN",
      "refreshToken": "YOUR_GOOGLE_REFRESH_TOKEN",
      "expiresAt": 0
    },
    {
      "connection_name": "GitHub",
      "connection_type": "github",
      "token": "ghp_YOUR_TOKEN",
      "owner": "your-org",
      "repo": "your-repo"
    },

    // ── HTTP connectors — LLM knows the API, just provide base URL + auth ────

    {
      "connection_name": "Telegram",
      "connection_type": "http",
      "baseUrl": "https://api.telegram.org/botYOUR_BOT_TOKEN"
    },
    {
      "connection_name": "Slack",
      "connection_type": "http",
      "baseUrl": "https://slack.com/api",
      "headers": { "Authorization": "Bearer xoxb-YOUR_BOT_TOKEN" }
    },
    {
      "connection_name": "Discord",
      "connection_type": "http",
      "baseUrl": "https://discord.com/api/v10",
      "headers": { "Authorization": "Bot YOUR_BOT_TOKEN" }
    },
    {
      "connection_name": "WhatsApp",
      "connection_type": "http",
      "baseUrl": "https://graph.facebook.com/v19.0/YOUR_PHONE_NUMBER_ID",
      "headers": { "Authorization": "Bearer YOUR_ACCESS_TOKEN" }
    },
    {
      "connection_name": "Notion",
      "connection_type": "http",
      "baseUrl": "https://api.notion.com/v1",
      "headers": {
        "Authorization": "Bearer secret_YOUR_TOKEN",
        "Notion-Version": "2022-06-28"
      }
    },
    {
      "connection_name": "Airtable",
      "connection_type": "http",
      "baseUrl": "https://api.airtable.com/v0/YOUR_BASE_ID",
      "headers": { "Authorization": "Bearer YOUR_API_KEY" }
    },
    {
      "connection_name": "HubSpot",
      "connection_type": "http",
      "baseUrl": "https://api.hubapi.com",
      "headers": { "Authorization": "Bearer YOUR_PRIVATE_APP_TOKEN" }
    },
    {
      "connection_name": "Salesforce",
      "connection_type": "http",
      "baseUrl": "https://YOUR_INSTANCE.salesforce.com/services/data/v59.0",
      "headers": { "Authorization": "Bearer YOUR_ACCESS_TOKEN" }
    },
    {
      "connection_name": "Stripe",
      "connection_type": "http",
      "baseUrl": "https://api.stripe.com/v1",
      "headers": { "Authorization": "Bearer sk_live_YOUR_SECRET_KEY" }
    },
    {
      "connection_name": "Twilio",
      "connection_type": "http",
      "baseUrl": "https://api.twilio.com/2010-04-01/Accounts/YOUR_ACCOUNT_SID",
      "headers": { "Authorization": "Basic BASE64_OF_ACCOUNTSID:AUTHTOKEN" }
    },
    {
      "connection_name": "SendGrid",
      "connection_type": "http",
      "baseUrl": "https://api.sendgrid.com/v3",
      "headers": { "Authorization": "Bearer SG.YOUR_API_KEY" }
    },
    {
      "connection_name": "Mailchimp",
      "connection_type": "http",
      "baseUrl": "https://usX.api.mailchimp.com/3.0",
      "headers": { "Authorization": "Bearer YOUR_API_KEY" }
    },
    {
      "connection_name": "Shopify",
      "connection_type": "http",
      "baseUrl": "https://YOUR_STORE.myshopify.com/admin/api/2024-01",
      "headers": {
        "X-Shopify-Access-Token": "YOUR_ACCESS_TOKEN",
        "Content-Type": "application/json"
      }
    },
    {
      "connection_name": "WooCommerce",
      "connection_type": "http",
      "baseUrl": "https://your-store.com/wp-json/wc/v3",
      "headers": { "Authorization": "Basic BASE64_OF_CONSUMER_KEY:CONSUMER_SECRET" }
    },
    {
      "connection_name": "Jira",
      "connection_type": "http",
      "baseUrl": "https://your-org.atlassian.net/rest/api/3",
      "headers": {
        "Authorization": "Basic BASE64_OF_EMAIL:API_TOKEN",
        "Accept": "application/json"
      }
    },
    {
      "connection_name": "Confluence",
      "connection_type": "http",
      "baseUrl": "https://your-org.atlassian.net/wiki/rest/api",
      "headers": {
        "Authorization": "Basic BASE64_OF_EMAIL:API_TOKEN",
        "Accept": "application/json"
      }
    },
    {
      "connection_name": "Linear",
      "connection_type": "http",
      "baseUrl": "https://api.linear.app/graphql",
      "headers": { "Authorization": "YOUR_API_KEY" }
    },
    {
      "connection_name": "Asana",
      "connection_type": "http",
      "baseUrl": "https://app.asana.com/api/1.0",
      "headers": { "Authorization": "Bearer YOUR_PERSONAL_ACCESS_TOKEN" }
    },
    {
      "connection_name": "Trello",
      "connection_type": "http",
      "baseUrl": "https://api.trello.com/1",
      "headers": { "Authorization": "OAuth oauth_consumer_key=\"YOUR_KEY\", oauth_token=\"YOUR_TOKEN\"" }
    },
    {
      "connection_name": "Monday",
      "connection_type": "http",
      "baseUrl": "https://api.monday.com/v2",
      "headers": { "Authorization": "YOUR_API_KEY" }
    },
    {
      "connection_name": "Zendesk",
      "connection_type": "http",
      "baseUrl": "https://YOUR_SUBDOMAIN.zendesk.com/api/v2",
      "headers": { "Authorization": "Basic BASE64_OF_EMAIL/token:API_TOKEN" }
    },
    {
      "connection_name": "Freshdesk",
      "connection_type": "http",
      "baseUrl": "https://YOUR_SUBDOMAIN.freshdesk.com/api/v2",
      "headers": { "Authorization": "Basic BASE64_OF_API_KEY:X" }
    },
    {
      "connection_name": "Intercom",
      "connection_type": "http",
      "baseUrl": "https://api.intercom.io",
      "headers": {
        "Authorization": "Bearer YOUR_ACCESS_TOKEN",
        "Accept": "application/json"
      }
    },
    {
      "connection_name": "Pipedrive",
      "connection_type": "http",
      "baseUrl": "https://api.pipedrive.com/v1",
      "headers": { "x-api-token": "YOUR_API_KEY" }
    },
    {
      "connection_name": "Apollo",
      "connection_type": "http",
      "baseUrl": "https://api.apollo.io/v1",
      "headers": {
        "x-api-key": "YOUR_API_KEY",
        "Content-Type": "application/json"
      }
    },
    {
      "connection_name": "Zoho CRM",
      "connection_type": "http",
      "baseUrl": "https://www.zohoapis.com/crm/v3",
      "headers": { "Authorization": "Zoho-oauthtoken YOUR_ACCESS_TOKEN" }
    },
    {
      "connection_name": "QuickBooks",
      "connection_type": "http",
      "baseUrl": "https://quickbooks.api.intuit.com/v3/company/YOUR_COMPANY_ID",
      "headers": { "Authorization": "Bearer YOUR_ACCESS_TOKEN" }
    },
    {
      "connection_name": "Xero",
      "connection_type": "http",
      "baseUrl": "https://api.xero.com/api.xro/2.0",
      "headers": {
        "Authorization": "Bearer YOUR_ACCESS_TOKEN",
        "Xero-tenant-id": "YOUR_TENANT_ID"
      }
    },
    {
      "connection_name": "OpenAI",
      "connection_type": "http",
      "baseUrl": "https://api.openai.com/v1",
      "headers": { "Authorization": "Bearer sk-YOUR_KEY" }
    },
    {
      "connection_name": "My API",
      "connection_type": "http",
      "baseUrl": "https://your-api.example.com/v1",
      "headers": {
        "Authorization": "Bearer YOUR_TOKEN",
        "Content-Type": "application/json"
      }
    },

    // ── Search ───────────────────────────────────────────────────────────────

    {
      "connection_name": "Perplexity Search",
      "connection_type": "perplexity-search",
      "apiKey": "pplx-YOUR_KEY"
    },
    {
      "connection_name": "Google Search",
      "connection_type": "google-search",
      "apiKey": "YOUR_GOOGLE_API_KEY",
      "searchEngineId": "YOUR_CX_ID"
    },
    {
      "connection_name": "Bing Search",
      "connection_type": "bing-search",
      "apiKey": "YOUR_BING_SUBSCRIPTION_KEY"
    },

    // ── OCR ──────────────────────────────────────────────────────────────────

    {
      "connection_name": "Azure Vision",
      "connection_type": "azure-vision",
      "endpoint": "https://YOUR_RESOURCE.cognitiveservices.azure.com",
      "apiKey": "YOUR_AZURE_KEY"
    },
    {
      "connection_name": "Google Vision",
      "connection_type": "google-vision",
      "apiKey": "YOUR_GOOGLE_API_KEY"
    },
    {
      "connection_name": "AWS Textract",
      "connection_type": "aws-textract",
      "accessKeyId": "YOUR_ACCESS_KEY_ID",
      "secretAccessKey": "YOUR_SECRET_KEY",
      "region": "us-east-1"
    },
    {
      "connection_name": "Tesseract OCR",
      "connection_type": "tesseract-ocr",
      "baseUrl": "http://localhost:8884"
    },

    // ── Image Generation ──────────────────────────────────────────────────────

    {
      "connection_name": "OpenAI Image",
      "connection_type": "openai-image",
      "apiKey": "sk-YOUR_OPENAI_KEY",
      "model": "gpt-image-1"
    },
    {
      "connection_name": "FLUX",
      "connection_type": "flux",
      "apiKey": "YOUR_TOGETHER_AI_KEY",
      "model": "black-forest-labs/FLUX.1-schnell-Free"
    },
    {
      "connection_name": "Stable Diffusion",
      "connection_type": "stable-diffusion",
      "apiKey": "YOUR_STABILITY_AI_KEY"
    },
    {
      "connection_name": "Ideogram",
      "connection_type": "ideogram",
      "apiKey": "YOUR_IDEOGRAM_KEY"
    },

    // ── Speech & Audio ────────────────────────────────────────────────────────

    {
      "connection_name": "ElevenLabs",
      "connection_type": "elevenlabs",
      "apiKey": "YOUR_ELEVENLABS_KEY",
      "voiceId": "EXAVITQu4vr4xnSDxMaL"
    },
    {
      "connection_name": "OpenAI TTS",
      "connection_type": "openai-tts",
      "apiKey": "sk-YOUR_OPENAI_KEY",
      "voice": "alloy"
    },
    {
      "connection_name": "Azure Speech",
      "connection_type": "azure-speech",
      "subscriptionKey": "YOUR_AZURE_SPEECH_KEY",
      "region": "eastus"
    },
    {
      "connection_name": "Google TTS",
      "connection_type": "google-tts",
      "apiKey": "YOUR_GOOGLE_API_KEY"
    },

    // ── Video Generation ──────────────────────────────────────────────────────

    {
      "connection_name": "Runway",
      "connection_type": "runway",
      "apiKey": "YOUR_RUNWAY_KEY"
    },
    {
      "connection_name": "Kling",
      "connection_type": "kling",
      "apiKey": "YOUR_KLING_KEY"
    },
    {
      "connection_name": "Pika",
